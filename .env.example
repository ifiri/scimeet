OLLAMA_HOST=http://127.0.0.1:11434
SCIMEET_EMBED_MODEL=nomic-embed-text
SCIMEET_CHAT_MODEL=llama3.1:8b
SCIMEET_TRANSLATE_MODEL=llama3.1:8b
SCIMEET_TRANSLATE_ON_QUERY=true
SCIMEET_TRANSLATE_ON_INGEST=false
SCIMEET_TRANSLATE_FALLBACK_TO_ORIGINAL=true
SCIMEET_DATA_DIR=data
SCIMEET_REQUEST_TIMEOUT_SECS=120
SCIMEET_CONNECT_TIMEOUT_SECS=30
SCIMEET_EMBED_DIM=768
SCIMEET_HTTP_POOL_MAX_IDLE_PER_HOST=8
SCIMEET_HTTP_POOL_IDLE_TIMEOUT_SECS=90
SCIMEET_HTTP_USER_AGENT=scimeet/0.1
